# ── OpenAI (for AI content brief generation) ──────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Google OAuth (for Search Console API) ─────────────────────────
# Step-by-step setup: see README.md → "Search Console Setup"
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Your app URL ───────────────────────────────────────────────────
# Local development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (replace with your Vercel URL):
# NEXT_PUBLIC_APP_URL=https://testbook-seo.vercel.app

# ── Default GSC property (optional) ───────────────────────────────
NEXT_PUBLIC_GSC_SITE=https://testbook.com/
